# Example service config for scripts/serve_up.sh.
#
# Usage:
#   set -a
#   source .env              # should export V_API_KEY (or adjust LLM_API_KEY_ENV below)
#   set +a
#   scripts/serve_up.sh configs/services/vapi.env.example
#
# For a private config, copy this file to configs/services/vapi.env and edit it.

# tmux / runtime
SESSION=robomex
VENV=.venv-libero
LOG_DIR=./logs/servers

# LIBERO / CapX GPU service config
CONFIG=env_configs/libero/franka_libero_cap_agent0.yaml

# Local proxy clients keep using http://localhost:8110/chat/completions.
LLM_PORT=8110

# V-API OpenAI-compatible base URL. Use the base URL, not /chat/completions.
LLM_BASE_URL=https://api.v3.cm/v1

# Read the real key from the environment so this config can stay committed.
LLM_API_KEY_ENV=V_API_KEY

# Forwarded to capx.serving.openrouter_server.
LLM_REASONING_EFFORT=low
LLM_TIMEOUT_S=600
